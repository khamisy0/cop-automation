// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Euro Retail reference table
// Stores article information with euro retail prices
model EuroRetail {
  id                    Int      @id @default(autoincrement())
  batchNumber           String
  lineNumber            String
  brandCode            String
  brandDescription     String
  mancode              String
  colorSize            String
  effectiveDate        DateTime
  importFileColor      String?  // Optional
  importFileSizeList   String?  // Optional
  euroRetail           Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([batchNumber, lineNumber])
  @@map("euro_retail")
}

// Price Matrix table
// Maps country/brand/season combinations to local retail prices
model PriceMatrix {
  id              Int     @id @default(autoincrement())
  country         String
  brandCode       String
  season          String
  supplier        String
  section         String?  // Optional empty field
  foreignRetailFOB Float   // Euro price
  unitRetail      Float   // Local price
  effectiveDate   DateTime
  expiryDate      DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([country, brandCode, season, supplier, foreignRetailFOB])
  @@map("price_matrix")
}

// Seasonality Reference table
// Centralized source of truth for variant collection active seasons
model SeasonalityReference {
  id               Int      @id @default(autoincrement())
  country          String   // Can be empty/null for generic entries
  priority         Int      // Lower number = higher priority
  fromDate1        String?  // From (date or identifier)
  mancode          String
  colorCode        String
  season           String   // Variant Collection Active Season
  fromDate2        String?  // From (second field)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Composite indexes for fast lookups during validation
  @@index([country, mancode, colorCode])
  @@index([mancode, colorCode])
  @@map("seasonality_reference")
}
